{
    "compilerOptions": {
        "target": "ES2020",
        "lib": [
            "ES2020"
        ],
        "module": "commonjs",
        "skipLibCheck": true,
        "strict": true,
        "esModuleInterop": true,
        "ignoreDeprecations": "6.0",
        "moduleResolution": "node",
        "resolveJsonModule": true,
        "isolatedModules": true,
        "incremental": true
    }
}